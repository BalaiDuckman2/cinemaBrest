# ===========================================
# ReelTime Docker Deployment Configuration
# ===========================================
# Copy this file to .env and fill in the values.

# --- PostgreSQL ---
POSTGRES_USER=reeltime
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=reeltime

# --- API ---
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_REFRESH_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
LOG_LEVEL=info
CORS_ORIGIN=http://localhost
API_PORT=3000

# --- Web ---
WEB_PORT=80

# ===========================================
# GitHub Actions Secrets (configure in GitHub)
# ===========================================
# These secrets must be set in GitHub repository settings
# under Settings > Secrets and variables > Actions:
#
# NAS_SSH_HOST     - NAS IP address or hostname
# NAS_SSH_USER     - SSH username for deployment
# NAS_SSH_KEY      - SSH private key (full PEM content)
# NAS_DEPLOY_PATH  - Absolute path to docker-compose dir on NAS
#                    (e.g., /volume1/docker/reeltime)
#
# Note: GITHUB_TOKEN is automatically available for ghcr.io
# container registry authentication.
