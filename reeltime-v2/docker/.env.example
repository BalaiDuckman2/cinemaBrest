# ===========================================
# ReelTime Docker Deployment Configuration
# ===========================================
# Copy this file to .env and fill in the values.

# --- API (requis) ---
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_REFRESH_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# --- API (optionnel) ---
LOG_LEVEL=info
CORS_ORIGIN=*

# --- Web ---
PORT=80

# ===========================================
# Déploiement via Portainer
# ===========================================
# 1. Dans Portainer : Stacks > Add stack
# 2. Coller le contenu de docker-compose.prod.yml
# 3. Ajouter JWT_SECRET et JWT_REFRESH_SECRET
#    dans "Environment variables"
# 4. Deploy
#
# Pour le redéploiement automatique (optionnel) :
# - Activer le webhook sur le stack Portainer
# - Copier l'URL du webhook
# - L'ajouter comme secret GitHub : PORTAINER_WEBHOOK_URL

# ===========================================
# GitHub Actions (configurer dans GitHub)
# ===========================================
# Secret optionnel pour auto-redéploiement :
# PORTAINER_WEBHOOK_URL - URL du webhook Portainer
#
# Note: GITHUB_TOKEN est automatiquement disponible
# pour l'authentification ghcr.io.
