generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

// Pour le developpement local, utiliser SQLite
// Pour la production, changer en "postgresql" et adapter DATABASE_URL
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// --- Enums ---

enum Version {
  VF
  VO
  VOST
  OTHER
}

// --- Models ---

model Cinema {
  id         Int      @id @default(autoincrement())
  allocineId String   @unique @map("allocine_id")
  name       String
  address    String?
  city       String
  latitude   Float?
  longitude  Float?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  showtimes Showtime[]

  @@map("cinemas")
}

model Film {
  id             Int       @id @default(autoincrement())
  allocineId     Int       @unique @map("allocine_id")
  title          String
  year           Int?
  posterUrl      String?   @map("poster_url")
  synopsis       String?
  cast           String    @default("[]")
  director       String?
  rating         Float?
  productionYear Int?      @map("production_year")
  releaseDate    DateTime? @map("release_date")
  runtime        Int?
  genres         String    @default("[]")
  filmAge        Int?      @map("film_age")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  showtimes Showtime[]

  @@map("films")
}

model Showtime {
  id         Int      @id @default(autoincrement())
  filmId     Int      @map("film_id")
  cinemaId   Int      @map("cinema_id")
  date       String   // YYYY-MM-DD for efficient date-range queries
  startsAt   DateTime @map("starts_at")
  version    Version  @default(OTHER)
  bookingUrl String?  @map("booking_url")
  createdAt  DateTime @default(now()) @map("created_at")

  film   Film   @relation(fields: [filmId], references: [id], onDelete: Cascade)
  cinema Cinema @relation(fields: [cinemaId], references: [id], onDelete: Cascade)

  @@unique([cinemaId, filmId, startsAt])
  @@index([cinemaId, date])
  @@index([date])
  @@index([filmId, date])
  @@map("showtimes")
}

model CacheMetadata {
  id        Int      @id @default(autoincrement())
  cacheKey  String   @unique @map("cache_key")
  fetchedAt DateTime @map("fetched_at")
  expiresAt DateTime @map("expires_at")

  @@map("cache_metadata")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String?
  isAdmin      Boolean  @default(false) @map("is_admin")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  watchlist     Watchlist[]
  alerts        Alert[]
  deviceTokens  DeviceToken[]

  @@index([email], name: "idx_users_email")
  @@map("users")
}

model Watchlist {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  filmTitle  String   @map("film_title")
  cinemaName String   @map("cinema_name")
  date       String
  time       String
  version    String
  bookingUrl String?  @map("booking_url")
  posterUrl  String?  @map("poster_url")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, filmTitle, cinemaName, date, time])
  @@map("watchlist")
}

model Alert {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  filmTitle   String    @map("film_title")
  criteria    String    @default("{}") // JSON stored as text (SQLite compatible)
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  triggeredAt DateTime? @map("triggered_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("alerts")
}

model DeviceToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  platform  String   // 'web', 'ios', 'android'
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("device_tokens")
}
