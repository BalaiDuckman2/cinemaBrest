DATABASE_URL=file:./dev.db          # SQLite for dev, postgresql://... for prod
JWT_SECRET=change-me-in-production  # Secret for access token signing
JWT_REFRESH_SECRET=change-me-in-production  # Secret for refresh token signing
PORT=3000                           # API server port
HOST=0.0.0.0                       # API server host
NODE_ENV=development                # development | production
CORS_ORIGIN=*                       # Comma-separated origins or *
LOG_LEVEL=info                      # trace | debug | info | warn | error | fatal
SKIP_PRELOAD=true                   # Skip 60-day preload at startup (set false in prod)
TIMEZONE=Europe/Paris               # Timezone for midnight sync scheduler
FIREBASE_PROJECT_ID=                # Firebase project ID (for push notifications)
FIREBASE_CLIENT_EMAIL=              # Firebase service account email
FIREBASE_PRIVATE_KEY=               # Firebase service account private key (with \n for newlines)
