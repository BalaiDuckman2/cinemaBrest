{
  "name": "@reeltime/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsc --build",
    "start": "node dist/server.js",
    "lint": "eslint . --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist .turbo",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/swagger": "^9.0.0",
    "@fastify/swagger-ui": "^5.0.0",
    "@prisma/client": "6.19.2",
    "bcrypt": "^6.0.0",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.1.0",
    "firebase-admin": "^13.6.1",
    "jsonwebtoken": "^9.0.3",
    "node-cache": "^5.1.2",
    "node-cron": "^3.0.0",
    "pino-pretty": "^13.0.0",
    "prom-client": "^15.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@reeltime/config": "workspace:*",
    "@reeltime/types": "workspace:*",
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.0",
    "eslint": "^8.57.0",
    "prisma": "6.19.2",
    "rimraf": "^6.0.0",
    "tsx": "^4.0.0",
    "typescript": "5.9.2",
    "vitest": "^4.0.18"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
