{
  "expo": {
    "name": "ReelTime",
    "slug": "reeltime",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "reeltime",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#1A1A1A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.reeltime.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1A1A1A"
      },
      "package": "com.reeltime.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      "expo-notifications"
    ]
  }
}
